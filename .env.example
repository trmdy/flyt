# Convex project generated by `npx convex dev`.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# Convex site origin. Better Auth appends /api/auth when no path is present.
# Example: https://your-deployment.convex.site
BETTER_AUTH_URL=
VITE_BETTER_AUTH_URL=

# Used by Better Auth trusted origins / cross-domain plugin in local dev.
PUBLIC_APP_URL=http://localhost:5173
VITE_PUBLIC_APP_URL=http://localhost:5173

# Generate a strong secret before using a shared deployment:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
